//SELECTING ALL THE ELEMENTS FROM THE HTML

// Declare uma variavel constante para cada elemento do HTML. document é um objeto global que representa o documento HTML. 
// querySelector é um método que retorna o primeiro elemento que corresponde ao seletor CSS especificado. 
//O valor dentro do parênteses é chamado de argumento, e é uma string que representa o seletor. 
//Parenteses no JavaScript sempre significa "Eu estou chamando uma função". O ponto é usado para acessar propriedades ou métodos de um objeto.

// Find ONE element in the HTML by its ID (Use # as it is in the HTML to select by ID).
const loginBtn = document.querySelector('#login-btn');       /// variavel constante = OBJECTO.METODO(SELETOR)
const profileDiv = document.querySelector('#profile');
const errorBox = document.querySelector('#error-box');

//Find ONE element by its class (Use . as it is in the HTML to select by class).
const card = document.querySelector('.profile-card');




//async marks a function as "this will do something that takes time"
async function getMyProfile() {

    
    const response = await fetch('https://api.github.com/user', {               // await means "wait here until this finishes before moving on"
        method: 'GET',
        headers: {
            'Authorization': 'Bearer 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',
            'Accept': 'application/vnd.github.v3+json'
        }
    });

    if (response.status === 401) {
        showError('401 - Unauthorized: Please check your GitHub token.It is missing or invalid!');
        return
    }

    if (response.status === 403) {
        showError('403 - Forbidden: Your token lacks the necessary permissions!');
        return;
    }

    if (!response.ok) {
        showError('Unexpected error: ' + response.status + ' - ' + response.statusText);
        return;
    }


    // response.json() is a method that parses the response body as JSON. It also returns a promise, so we need to await it as well.
    const data = await response.json();

    //Now data is a JavaScript object that you can use 
    console.log(data.login);    // prints your Github username to the console
    console.log(data.name);    // prints your Display  name to the console


    document.querySelector('#username').textContent = data.name;  

    document.querySelector('#avatar').src = data.avatar_url; 

    document.querySelector('#profile').classList.remove('hidden');  


    //Build HTML dynamically and insert it into the page
    document.querySelector('#repo-count').textContent = `Public repos: ${data.public_repos}`;

}
